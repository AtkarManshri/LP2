// CREATE EMAIL

Messaging.SingleEmailMessage mail =
    new Messaging.SingleEmailMessage();

mail.setToAddresses(
    new String[] {'atkarmanshri@gmail.com'}
);

mail.setCcAddresses(
    new String[] {'atkarmanshri@gmail.com'}
);

